{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "autocomplete: build",
      "type": "shell",
      "command": "make",
      "options": {
        "cwd": "${workspaceFolder}/autocomplete"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "theodore: dev",
      "type": "shell",
      "command": "pnpm run dev",
      "options": {
        "cwd": "${workspaceFolder}/theodore"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "playground: dev",
      "type": "shell",
      "command": "pnpm run dev",
      "options": {
        "cwd": "${workspaceFolder}/playground"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "autocomplete: server",
      "type": "shell",
      "command": "./bin/autocomplete",
      "options": {
        "cwd": "${workspaceFolder}/autocomplete"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "theodore: parallel dev (playground, theodore)",
      "dependsOn": ["theodore: dev", "playground: dev"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
